# Confinia APPLICATION caddy: plain HTTP on 127.0.0.1:8085, behind the
# platform's UPSTREAM caddy (~/projects/platform on the VM), which owns
# 80/443 and the certificates and routes the confinia hostnames here.
# Zero-downtime reload: ./deploy/deploy-edge.sh (ephemeral validation + reload).
{
	http_port 8085
	auto_https off
	# VM RULE: every host-network caddy MUST have a UNIQUE admin address.
	# By default they all share localhost:2019 and a `caddy reload`
	# can load its config into the process of ANOTHER caddy (general
	# outage of 2026-07-20, the 8085 config swallowed by the upstream).
	# Convention: admin = 2000 + application port % 10000 -> confinia: 2085.
	admin localhost:2085
	# The UPSTREAM caddy talks to us from the local loopback: without this
	# trust, caddy THROWS AWAY its X-Forwarded-For (2.5+ behavior) and the
	# whole planet reaches the API as IP 127.0.0.1 (GLOBAL premium quota,
	# rate limit useless, country analytics degraded — issue #12). The
	# upstream overwrites client-supplied XFF: no spoofing possible from outside.
	servers {
		trusted_proxies static private_ranges
	}
}

# Anti-scanner filter: cuts off dead (abort = connection closed, no response)
# bot probes (secrets files, .git repositories, WordPress/PHP kits…).
# ENRICHMENT LOOP: the Grafana panel "404 by path" (Confinia API dashboard,
# Security row) lists what still gets through; new patterns are poured in
# here as they show up. Never: /robots.txt /sitemap.xml /favicon.ico
# (legitimate crawlers), nor any broad pattern breaking /openapi.json
# or the site assets.
(block_scanners) {
	# A named matcher can only be defined ONCE: one matcher per group.
	# dotfiles & repositories (at the root and at any depth)
	@scan_dotfiles path /.env /.env* */.env* /.git /.git* */.git/* /.aws /.aws* */.aws/* /.svn* /.hg* /.ssh* /.npmrc /.dockercfg /.docker* /.DS_Store /.vscode* /.idea* /.bash_history //*
	abort @scan_dotfiles
	# PHP / WordPress / e-commerce
	@scan_php path *.php *.php* /stripe /stripe/* /wp-admin* /wp-login* /wp-content* /wp-includes* /xmlrpc.php /vendor/*
	abort @scan_php
	# secrets files & configs (unambiguous names, at any depth)
	@scan_secrets path */terraform.tf* */serviceAccountKey.json */service_account.json */service-account.json */firebase-adminsdk.json */firebase.json */gcp-credentials.json */aws-exports.js */awsconfiguration.json */amplifyconfiguration.json */secrets.json */keys.json */key.json */token.json */env.json */env.js */local_settings.py */instance/config.py */application.properties */application.yml /aws-ses.json /aws-config.js /credentials* /config.json*
	abort @scan_secrets
	# infra configs (root only: too generic at depth)
	@scan_infra path /settings.json /web.config /vercel.json /netlify.toml /serverless.yml /docker-compose.yml /config.yml /config.js /graphql /debug/vars /sellers.json /app-ads.txt /ads.txt
	abort @scan_infra
	# phishing kits (probes for signature js/css files)
	@scan_phishkit path /bot-connect.js /js/twint_ch.js /js/lkk_ch.js /js/antibot-client.js /css/support_parent.css /static/style/* /assets/js/auth.js /assets/js/message.js /assets/js/qr_modal.js
	abort @scan_phishkit
}

# COLOR stack load balancing: the upstream order (active color first)
# lives in a STATE file generated by deploy/stacks.sh promote,
# mounted from ~/confinia-edge-state (OUTSIDE the rsync mirror: it
# survives synchronizations). It defines (api_upstreams) and (staging_upstreams).
# (also defines (staging_auth): credentials generated from secrets.env
# by deploy/stacks.sh, as literals: the admin reload does not resolve {env.*})
import /etc/caddy/active/*.caddy

# Confinia frontend (founder's request): the DEMO is the www homepage;
# the pitch/quickstart lives on /about, the blog keeps its published URLs
# (/blog/*). Canonical paths: /api/ (API) and /grafana (APPLICATION grafana).
http://www.confinia.io {
	encode zstd gzip
	handle /grafana* {
		reverse_proxy 127.0.0.1:3000
	}
	# bare /api -> /api/ (probes and humans type it without a trailing slash).
	redir /api /api/ 308
	handle_path /api/* {
		route {
			import block_scanners
			import api_upstreams
		}
	}
	# Blog: published URLs (Marseille article…), served from the site.
	handle /blog* {
		root * /srv/site
		file_server
	}
	# API pitch + quickstart + attributions: moved to /about.
	handle /about {
		root * /srv/site
		rewrite * /index.html
		file_server
	}
	# Keycloak IdP (issue #19): relative path /auth, local container 8180.
	# The ADMIN console and the master realm are NEVER exposed publicly:
	# administer through an SSH tunnel (ssh -L 8180:127.0.0.1:8180).
	handle /auth/* {
		@kc_admin path /auth/admin* /auth/realms/master*
		respond @kc_admin 403
		reverse_proxy 127.0.0.1:8180
	}
	# Pricing + intent capture (issue #7): the purchase surface.
	handle /pricing {
		root * /srv/site
		rewrite * /pricing.html
		file_server
	}
	# Detailed commune page (issue #14): /commune/<code>.
	handle /commune/* {
		root * /srv/site
		rewrite * /commune.html
		file_server
	}
	# Homepage: the demo (the product that demonstrates itself).
	handle {
		root * /srv/demo
		route {
			import block_scanners
			file_server
		}
	}
}

# Historical API hostname: published everywhere (OHM posts, OpenCage
# backlink, README, release): NEVER break it.
http://api.confinia.io {
	encode zstd gzip
	route {
		import block_scanners
		import api_upstreams
	}
}

# Human validation before promotion, behind BASIC AUTH (credentials via
# the container env: never in the repo). Demo (VM mirror) + candidate API
# on the same origin under /api: a single login covers everything.
http://staging.confinia.io {
	import staging_auth
	encode zstd gzip
	handle_path /api/* {
		import staging_upstreams
	}
	# Validation of the pricing page before www exposure.
	handle /pricing {
		root * /srv/site
		rewrite * /pricing.html
		file_server
	}
	handle /commune/* {
		root * /srv/site
		rewrite * /commune.html
		file_server
	}
	handle {
		root * /srv/demo
		file_server
	}
}

# Candidate API alone (curl), same credentials.
http://staging.api.confinia.io {
	import staging_auth
	encode zstd gzip
	route {
		import block_scanners
		import staging_upstreams
	}
}

# Historical demo hostname: the demo is now the www homepage (same
# content as the GitHub Pages mirror) — we redirect there.
# permanent: www is the canonical origin (decision of 2026-07-20).
http://time-slider.confinia.io {
	redir https://www.confinia.io{uri} permanent
}
