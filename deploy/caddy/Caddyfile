# Caddy APPLICATIF confinia : HTTP simple sur 127.0.0.1:8085, derrière le
# caddy AMONT de la plateforme (~/projects/platform sur la VM), qui possède
# 80/443 et les certificats et route les hostnames confinia vers ici.
# Reload sans coupure : ./deploy/deploy-edge.sh (validation éphémère + reload).
{
	http_port 8085
	auto_https off
	# RÈGLE VM : chaque caddy en réseau hôte DOIT avoir une adresse admin
	# UNIQUE. Par défaut tous partagent localhost:2019 et un `caddy reload`
	# peut charger sa config dans le processus d'un AUTRE caddy (panne
	# générale du 2026-07-20, config 8085 avalée par l'amont). Convention :
	# admin = 2000 + port applicatif % 10000 -> confinia : 2085.
	admin localhost:2085
}

# Filtre anti-scanners : coupe net (abort = connexion fermée, aucune réponse)
# les sondes de bots (fichiers de secrets, dépôts .git, kits WordPress/PHP…).
# BOUCLE D'ENRICHISSEMENT : le panneau Grafana « 404 par chemin » (dashboard
# Confinia API, rangée Sécurité) liste ce qui passe encore ; on verse ici les
# nouveaux motifs au fil de l'eau. Jamais : /robots.txt /sitemap.xml
# /favicon.ico (crawlers légitimes), ni de motif large cassant /openapi.json
# ou les assets du site.
(block_scanners) {
	# Un matcher nommé ne peut être défini qu'UNE fois : un matcher par groupe.
	# dotfiles & dépôts (à la racine et en profondeur)
	@scan_dotfiles path /.env /.env* */.env* /.git /.git* */.git/* /.aws /.aws* */.aws/* /.svn* /.hg* /.ssh* /.npmrc /.dockercfg /.docker* /.DS_Store /.vscode* /.idea* /.bash_history //*
	abort @scan_dotfiles
	# PHP / WordPress / e-commerce
	@scan_php path *.php *.php* /stripe /stripe/* /wp-admin* /wp-login* /wp-content* /wp-includes* /xmlrpc.php /vendor/*
	abort @scan_php
	# fichiers de secrets & configs (noms non ambigus, à toute profondeur)
	@scan_secrets path */terraform.tf* */serviceAccountKey.json */service_account.json */service-account.json */firebase-adminsdk.json */firebase.json */gcp-credentials.json */aws-exports.js */awsconfiguration.json */amplifyconfiguration.json */secrets.json */keys.json */key.json */token.json */env.json */env.js */local_settings.py */instance/config.py */application.properties */application.yml /aws-ses.json /aws-config.js /credentials* /config.json*
	abort @scan_secrets
	# configs d'infra (racine uniquement : trop génériques en profondeur)
	@scan_infra path /settings.json /web.config /vercel.json /netlify.toml /serverless.yml /docker-compose.yml /config.yml /config.js /graphql /debug/vars /sellers.json /app-ads.txt /ads.txt
	abort @scan_infra
	# kits de phishing (sondes de fichiers js/css signatures)
	@scan_phishkit path /bot-connect.js /js/twint_ch.js /js/lkk_ch.js /js/antibot-client.js /css/support_parent.css /static/style/* /assets/js/auth.js /assets/js/message.js /assets/js/qr_modal.js
	abort @scan_phishkit
}

# Équilibrage des stacks COULEUR : l'ordre des upstreams (couleur active en
# tête) vit dans un fichier d'ÉTAT généré par deploy/stacks.sh promote,
# monté depuis ~/confinia-edge-state (HORS miroir rsync : il survit aux
# synchronisations). Il définit (api_upstreams) et (staging_upstreams).
# (définit aussi (staging_auth) : identifiants générés depuis secrets.env
# par deploy/stacks.sh, en littéral : le reload admin ne résout pas {env.*})
import /etc/caddy/active/*.caddy

# Frontend confinia (demande fondateur) : la DÉMO est la page d'accueil de
# www ; le pitch/quickstart vit sur /about, le blog garde ses URLs publiées
# (/blog/*). Chemins canoniques : /api/ (API) et /grafana (grafana APPLICATIF).
http://www.confinia.io {
	encode zstd gzip
	handle /grafana* {
		reverse_proxy 127.0.0.1:3000
	}
	# /api nu -> /api/ (les sondes et les humains tapent sans slash final).
	redir /api /api/ 308
	handle_path /api/* {
		route {
			import block_scanners
			import api_upstreams
		}
	}
	# Blog : URLs publiées (article Marseille…), servies depuis le site.
	handle /blog* {
		root * /srv/site
		file_server
	}
	# Pitch API + quickstart + attributions : déplacé sur /about.
	handle /about {
		root * /srv/site
		rewrite * /index.html
		file_server
	}
	# Tarifs + capture d'intention (issue #7) : la surface d'achat.
	handle /pricing {
		root * /srv/site
		rewrite * /pricing.html
		file_server
	}
	# Accueil : la démo (le produit qui se démontre tout seul).
	handle {
		root * /srv/demo
		route {
			import block_scanners
			file_server
		}
	}
}

# Hostname historique de l'API : publié partout (posts OHM, backlink
# OpenCage, README, release) : NE JAMAIS le casser.
http://api.confinia.io {
	encode zstd gzip
	route {
		import block_scanners
		import api_upstreams
	}
}

# Validation humaine pré-promotion, derrière BASIC AUTH (identifiants via
# l'env du conteneur : jamais dans le repo). Démo (miroir VM) + API candidate
# en même origine sous /api : un seul login couvre tout.
http://staging.confinia.io {
	import staging_auth
	encode zstd gzip
	handle_path /api/* {
		import staging_upstreams
	}
	# Validation de la page tarifs avant exposition www.
	handle /pricing {
		root * /srv/site
		rewrite * /pricing.html
		file_server
	}
	handle {
		root * /srv/demo
		file_server
	}
}

# API candidate seule (curl), mêmes identifiants.
http://staging.api.confinia.io {
	import staging_auth
	encode zstd gzip
	route {
		import block_scanners
		import staging_upstreams
	}
}

# Hostname historique de la démo : la démo est désormais la page d'accueil
# de www (même contenu que le miroir GitHub Pages) — on y redirige.
# permanent : www est l'origine canonique (décision 2026-07-20).
http://time-slider.confinia.io {
	redir https://www.confinia.io{uri} permanent
}
