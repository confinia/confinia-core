{
  "title": "Confinia API",
  "uid": "confinia-api",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Requêtes / s par route",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (route) (rate(confinia_requests_total[5m]))",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "id": 2, "type": "timeseries", "title": "Latence p50 / p95 (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 3, "type": "piechart", "title": "Requêtes par pays (24 h)",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum by (country) (increase(confinia_requests_total[24h]))",
        "legendFormat": "{{country}}"
      }]
    },
    {
      "id": 4, "type": "timeseries", "title": "Statuts HTTP",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum by (status) (rate(confinia_requests_total[5m]))",
        "legendFormat": "{{status}}"
      }]
    },
    {
      "id": 5, "type": "table", "title": "Top routes (24 h)",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [{
        "expr": "topk(10, sum by (route) (increase(confinia_requests_total[24h])))",
        "format": "table", "instant": true
      }]
    }
  ],
  "schemaVersion": 39
}
