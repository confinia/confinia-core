{
  "title": "Confinia API",
  "uid": "confinia-api",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Requêtes / s par route",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (route) (rate(confinia_requests_total[5m]))",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "id": 2, "type": "timeseries", "title": "Latence p50 / p95 (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 3, "type": "piechart", "title": "Requêtes par pays (24 h)",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum by (country) (increase(confinia_requests_total[24h]))",
        "legendFormat": "{{country}}"
      }]
    },
    {
      "id": 4, "type": "timeseries", "title": "Statuts HTTP",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum by (status) (rate(confinia_requests_total[5m]))",
        "legendFormat": "{{status}}"
      }]
    },
    {
      "id": 5, "type": "table", "title": "Top routes (24 h)",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [{
        "expr": "topk(10, sum by (route) (increase(confinia_requests_total[24h])))",
        "format": "table", "instant": true
      }]
    },
    {
      "id": 6, "type": "stat", "title": "Visiteurs uniques (aujourd'hui)",
      "gridPos": { "x": 0, "y": 16, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "confinia-pg" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } },
      "targets": [{
        "rawSql": "SELECT count(*) FROM visitor_daily WHERE day = CURRENT_DATE",
        "format": "table", "rawQuery": true
      }]
    },
    {
      "id": 7, "type": "stat", "title": "Pays visiteurs (aujourd'hui)",
      "gridPos": { "x": 0, "y": 20, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "confinia-pg" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } },
      "targets": [{
        "rawSql": "SELECT count(DISTINCT country) FROM visitor_daily WHERE day = CURRENT_DATE",
        "format": "table", "rawQuery": true
      }]
    },
    {
      "id": 8, "type": "table", "title": "Visiteurs uniques par pays (aujourd'hui)",
      "gridPos": { "x": 4, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "confinia-pg" },
      "targets": [{
        "rawSql": "SELECT country AS pays, count(*) AS visiteurs FROM visitor_daily WHERE day = CURRENT_DATE GROUP BY 1 ORDER BY 2 DESC",
        "format": "table", "rawQuery": true
      }]
    },
    {
      "id": 9, "type": "timeseries", "title": "Visiteurs uniques par jour et pays (30 j)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "confinia-pg" },
      "fieldConfig": { "defaults": { "min": 0, "custom": {
        "drawStyle": "bars", "fillOpacity": 75, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "rawSql": "SELECT day::timestamptz AS time, country AS metric, count(*)::float8 AS value FROM visitor_daily WHERE day > CURRENT_DATE - 30 GROUP BY 1, 2 ORDER BY 1",
        "format": "time_series", "rawQuery": true
      }]
    }
  ],
  "schemaVersion": 39
}
