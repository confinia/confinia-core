{
  "title": "Confinia VM",
  "uid": "confinia-vm",
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "CPU",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 } ] } } },
      "targets": [{ "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))" }]
    },
    {
      "id": 2, "type": "stat", "title": "RAM utilisée",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 } ] } } },
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)" }]
    },
    {
      "id": 3, "type": "stat", "title": "Disque / utilisé",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 } ] } } },
      "targets": [{ "expr": "100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"})" }]
    },
    {
      "id": 4, "type": "stat", "title": "Charge (1 min)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "decimals": 2, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 6 }, { "color": "red", "value": 8 } ] } } },
      "targets": [{ "expr": "node_load1" }]
    },
    {
      "id": 5, "type": "stat", "title": "Uptime",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null } ] } } },
      "targets": [{ "expr": "time() - node_boot_time_seconds" }]
    },
    {
      "id": 6, "type": "stat", "title": "Cœurs CPU",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null } ] } } },
      "targets": [{ "expr": "count(count by (cpu) (node_cpu_seconds_total{mode=\"idle\"}))" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "CPU par mode (%)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0,
        "custom": { "lineWidth": 2, "fillOpacity": 0 } } },
      "targets": [{
        "expr": "100 * sum by (mode) (rate(node_cpu_seconds_total{mode!=\"idle\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{mode=\"idle\"}))",
        "legendFormat": "{{mode}}"
      }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Mémoire",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0,
        "custom": { "lineWidth": 2, "fillOpacity": 0 } } },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "utilisée" },
        { "expr": "node_memory_Cached_bytes + node_memory_Buffers_bytes", "legendFormat": "cache + buffers" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "disponible" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Réseau (bit/s)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bps", "min": 0,
        "custom": { "lineWidth": 2, "fillOpacity": 0 } } },
      "targets": [
        { "expr": "8 * rate(node_network_receive_bytes_total{device!~\"lo|veth.*|podman.*|cni.*|br.*|tap.*\"}[5m])", "legendFormat": "{{device}} entrant" },
        { "expr": "8 * rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|podman.*|cni.*|br.*|tap.*\"}[5m])", "legendFormat": "{{device}} sortant" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Débit disque",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0,
        "custom": { "lineWidth": 2, "fillOpacity": 0 } } },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{device=~\"sd.*|nvme.*|vd.*\"}[5m])", "legendFormat": "{{device}} lecture" },
        { "expr": "rate(node_disk_written_bytes_total{device=~\"sd.*|nvme.*|vd.*\"}[5m])", "legendFormat": "{{device}} écriture" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "IOPS",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "iops", "min": 0,
        "custom": { "lineWidth": 2, "fillOpacity": 0 } } },
      "targets": [
        { "expr": "rate(node_disk_reads_completed_total{device=~\"sd.*|nvme.*|vd.*\"}[5m])", "legendFormat": "{{device}} lecture" },
        { "expr": "rate(node_disk_writes_completed_total{device=~\"sd.*|nvme.*|vd.*\"}[5m])", "legendFormat": "{{device}} écriture" }
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Occupation IO (%)",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "custom": { "lineWidth": 2, "fillOpacity": 0 } } },
      "targets": [{
        "expr": "100 * rate(node_disk_io_time_seconds_total{device=~\"sd.*|nvme.*|vd.*\"}[5m])",
        "legendFormat": "{{device}}"
      }]
    },
    {
      "id": 13, "type": "timeseries", "title": "Systèmes de fichiers utilisés (%)",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "custom": { "lineWidth": 2, "fillOpacity": 0 } } },
      "targets": [{
        "expr": "100 * (1 - node_filesystem_avail_bytes{fstype=~\"ext4|xfs|btrfs\"} / node_filesystem_size_bytes{fstype=~\"ext4|xfs|btrfs\"})",
        "legendFormat": "{{mountpoint}}"
      }]
    }
  ],
  "schemaVersion": 39
}
