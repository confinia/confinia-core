# Confinia — routage public (VM OVH). HTTPS automatique via Let's Encrypt.
# DNS : enregistrement A wildcard *.confinia.io -> IP de la VM.

# Filtre anti-scanners : coupe net (abort = connexion fermée, aucune réponse)
# les sondes de bots (fichiers de secrets, dépôts .git, kits WordPress/PHP…).
# Placé DANS un `route` avant le backend : la requête n'atteint jamais FastAPI,
# donc elle ne pollue pas l'observabilité (OTel/Prometheus/Grafana).
# NB : n'attrape PAS /.well-known (ACME) — les motifs sont énumérés, pas /.* global.
(block_scanners) {
	@scanner path /.env /.env* /.git /.git* /.aws /.aws* /.svn* /.hg* /.ssh* /.npmrc /.dockercfg /.docker* /.DS_Store /.vscode* /.idea* /.bash_history *.php *.php* /stripe /stripe/* /wp-admin* /wp-login* /wp-content* /wp-includes* /xmlrpc.php /vendor/* /aws-ses.json /aws-config.js /assets/js/auth.js /assets/js/message.js /assets/js/qr_modal.js /credentials* /config.json* //*
	abort @scanner
}

api.confinia.io {
	encode zstd gzip
	route {
		import block_scanners
		reverse_proxy 127.0.0.1:8000
	}
}

# La démo vit sur GitHub Pages ; le wildcard DNS amène ce nom ici, caddy
# obtient le certificat et redirige (302 : réversible si la démo change
# d'hébergement ou passe en domaine custom GitHub Pages natif).
time-slider.confinia.io {
	redir https://confinia.github.io{uri} temporary
}

# Grafana (observabilité) — authentification gérée par Grafana lui-même
# (mot de passe admin dans deploy/secrets.env, inscriptions désactivées).
grafana.confinia.io {
	reverse_proxy 127.0.0.1:3000
}

confinia.io, www.confinia.io {
	encode zstd gzip
	root * /srv/site
	route {
		import block_scanners
		file_server
	}
}

# Vhosts des autres projets hébergés sur la VM (un fichier par projet,
# déposé dans deploy/sites/ — monté sur /etc/caddy/sites). Ce caddy est
# l'edge partagé de la VM : il possède 80/443, les backends publient en
# 127.0.0.1 uniquement. Ex. : overwatch.caddy (projects/overwatch).
import sites/*.caddy
